{{!-- Componente: Grid de artículos --}}
<div class="gh-articles-grid">
    <h3 class="gh-articles-title">Todos los artículos</h3>
    
    {{#foreach posts}}
        <article class="gh-article-card">
            {{#if feature_image}}
                <div class="gh-article-card-image">
                    <img 
                        srcset="{{img_url feature_image size="s"}} 300w,
                                {{img_url feature_image size="m"}} 720w"
                        sizes="(max-width: 1200px) 100vw, 720px"
                        src="{{img_url feature_image size="m"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    >
                </div>
            {{/if}}
            
            <div class="gh-article-card-content">
                <h4 class="gh-article-card-title">
                    <a href="{{url}}">{{title}}</a>
                </h4>
                
                {{#if excerpt}}
                    <p class="gh-article-card-excerpt">{{excerpt}}</p>
                {{/if}}
                
                <footer class="gh-article-card-meta">
                    {{#if primary_author}}
                        <span class="gh-article-card-author">{{primary_author.name}}</span>
                    {{/if}}
                    <span class="gh-article-card-date">
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM"}}</time>
                    </span>
                </footer>
            </div>
        </article>
    {{/foreach}}
</div>
